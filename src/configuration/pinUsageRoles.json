{
    "_comment": "MCU-independent roles required by each config field. Hardware tags (input-only GPIO, PSRAM, …) come later per MCU.",
    "taxonomy": {
        "fieldRoles": {
            "output": "Digital output (drive HIGH/LOW): CS, RST, LED, buzzer, UART TX, camera control, power enable.",
            "input": "Digital input (read level): UART RX, card detect, IRQ, parallel camera sync/data in.",
            "bidirectional": "Digital in+out on same line or bus bit: SPI MOSI/MISO, SDIO, MDIO, DHT one-wire, I2C SCCB (open-drain).",
            "analog_input": "ADC reading only (e.g. analog sensor).",
            "optional_gpio": "May be -1 (unused); when set, same rules as sibling role in notes."
        },
        "hardwareTags": {
            "_note": "Not field roles — applied per GPIO per MCU when building pin pickers.",
            "reserved": "Flash / PSRAM / strapping / USB — never offered (see psramReservedPins.js).",
            "input_only": "GPIO cannot be configured as output (ESP32: 34–39).",
            "output_only": "GPIO cannot be configured as input (rare on ESP32).",
            "adc": "Valid ADC channel when analog read is needed.",
            "bidirectional": "Normal GPIO (input+output)."
        },
        "userProposalMapping": {
            "Any (Input/Output/ADC)": "Too loose for validation — use bidirectional or split by field.",
            "Input/Output (Not ADC)": "≈ bidirectional (digital features).",
            "Input only": "Hardware tag, not a field role — use with input fields.",
            "Output only": "Hardware tag — use with output fields.",
            "Input only ADC": "Hardware tag — required for analog_input fields.",
            "Output only ADC": "Not used on ESP32 (no ADC output); use output or DAC later if needed.",
            "Reserved": "hardwareTags.reserved — orthogonal to field roles."
        },
        "recommendedMinimum": [
            "output",
            "input",
            "bidirectional",
            "analog_input",
            "reserved (hardware only)"
        ]
    },
    "fields": {
        "ESP_RX_PIN": { "role": "input", "group": "serial", "label": "Main serial RX" },
        "ESP_TX_PIN": { "role": "output", "group": "serial", "label": "Main serial TX" },
        "ESP_BRIDGE_RX_PIN": { "role": "input", "group": "serial", "label": "Bridge serial RX" },
        "ESP_BRIDGE_TX_PIN": { "role": "output", "group": "serial", "label": "Bridge serial TX" },

        "oledrstpin": { "role": "output", "group": "display", "label": "OLED reset", "notes": "optional -1" },
        "tftledpin": { "role": "output", "group": "display", "label": "TFT backlight" },
        "tftDCpin": { "role": "output", "group": "display", "label": "TFT DC" },
        "tftRSTpin": { "role": "output", "group": "display", "label": "TFT reset" },
        "tftCSpin": { "role": "output", "group": "display", "label": "TFT CS" },
        "tftMOSIpin": { "role": "bidirectional", "group": "display", "label": "TFT MOSI", "notes": "SPI master out; output-heavy" },
        "tftSCKpin": { "role": "output", "group": "display", "label": "TFT SCK" },

        "buzzerpin": { "role": "output", "group": "devices", "label": "Buzzer" },
        "sensorpin": {
            "role": "input",
