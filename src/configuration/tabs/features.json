                    {
                        "label": "ESP8266",
                        "value": "esp8266"
                    },
                    {
                        "label": "ESP32",
                        "value": "esp32"
                    },
                    {
                        "label": "ESP32-S2",
                        "value": "esp32s2"
                    },
                    {
                        "label": "ESP32-S3",
                        "value": "esp32s3"
                    },
                    {
                        "label": "ESP32-C3",
                        "value": "esp32c3"
                    },
                    {
                        "label": "ESP32-C6",
                        "value": "esp32c6"
                    }
                ]
            },
            {
                "id": "targetflashsize",
                "define": "FLASH_SIZE",
                "description": "ESP flash size",
                "label": "ESP flash size",
