                    },
                    {
                        "label": "8MB",
                        "value": "8"
                    },
                    {
                        "label": "16MB",
                        "value": "16"
                    }
                ]
            },
            {
                "id": "formfactor",
                "define": "ESP_FORM_FACTOR",
                "description": "Pins form factor",
                "label": "Form factor",
                "type": "select",
                "value": "original",
                "setting": false,
                "options": [
                    {
                        "label": "Original (all pins)",
                        "value": "original"
                    },
                    {
                        "label": "ESP01 (8 pins)",
                        "value": "esp01"
                    }
                ]
            },
            {
                "id": "flash_mod1",
                "define": "flash_mode",
                "description": "Flash mode",
                "label": "Flash mode",
                "type": "select",
